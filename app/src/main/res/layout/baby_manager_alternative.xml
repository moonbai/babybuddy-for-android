<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Timer section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/alternative_timer_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingVertical="8dp" />

            <RadioGroup
                android:id="@+id/timerRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/radioFeeding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/alternative_feeding"
                    android:textSize="16sp"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/radioSleep"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/alternative_sleep"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/radioTummyTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/alternative_tummy_time"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/radioPumping"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/alternative_pumping"
                    android:textSize="16sp" />

            </RadioGroup>

            <!-- Start/Stop timer button -->
            <Button
                android:id="@+id/btnStartStopTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/alternative_start_timer"
                android:textSize="16sp"
                android:padding="12dp" />

            <!-- Separator line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <!-- Quick log section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/alternative_quick_log_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingVertical="8dp" />

            <RadioGroup
                android:id="@+id/quickLogRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/radioDiaper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/alternative_diaper"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/radioNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/alternative_notes"
                    android:textSize="16sp" />

            </RadioGroup>

            <!-- Quick log button -->
            <Button
                android:id="@+id/btnQuickLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/alternative_log"
                android:textSize="16sp"
                android:padding="12dp" />

            <!-- Separator line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <!-- Timeline title -->
            <TextView
                android:id="@+id/timelineTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timeline_title_line_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal" />

            <!-- Timeline -->
            <LinearLayout
                android:id="@+id/innerTimeline"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <!-- Loading spinner -->
            <ProgressBar
                android:id="@+id/timelineProgressSpinner"
                style="?android:attr/progressBarStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
